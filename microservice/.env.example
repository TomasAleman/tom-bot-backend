# Variables que necesita src/server.js (ver README del repo)
PORT=3000
PGURL=postgres://evo:CAMBIAR@postgres:5432/evolution
REDIS_URL=redis://redis:6379
EVOLUTION_URL=http://evolution-api:8080
GROQ_API_KEY=CAMBIAR
JWT_SECRET=CAMBIAR_GENERAR_CON_openssl_rand_hex_48
PANEL_PUBLIC_DIR=/opt/tombot/panel-public
LOG_LEVEL=info
# Opcionales: evitar colgarse si Postgres no responde o el pool esta lleno
REQUEST_TIMEOUT_MS=120000
PG_POOL_MAX=20
PG_POOL_CONNECTION_TIMEOUT_MS=15000
PG_POOL_IDLE_TIMEOUT_MS=30000
PG_STATEMENT_TIMEOUT_SUPERADMIN_MS=45000
PG_DEFAULT_STATEMENT_TIMEOUT_MS=120000
