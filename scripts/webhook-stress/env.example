# Copiar a .env y cargar según tu shell, o exportar a mano.
# No commitear URLs reales si el repo es público.

# Obligatoria: origen sin barra final
BASE_URL=https://n8n.ejemplo.com

# Ruta del webhook (debe empezar con /)
# n8n Reservas v2:
WEBHOOK_PATH=/webhook/whatsapp-reservas-v2
# Fastify hot path:
# WEBHOOK_PATH=/webhook/whatsapp-reservas-fast

# Opcional: forzar modo respuesta (por defecto se infiere del path)
# TARGET=fastify

# Nombre de instancia Evolution que resuelve a tu tenant en Postgres (mismo que en prod)
INSTANCE_NAME=nombre_instancia_evolution

# Texto del mensaje entrante (afecta qué rama dispara n8n)
MESSAGE_TEXT=Hola, quiero reservar mesa para 2 personas mañana a las 20hs

# Rampas k6 (VU = usuarios virtuales concurrentes)
STAGE1_DURATION_SEC=30
STAGE1_TARGET=10
STAGE2_DURATION_SEC=120
STAGE2_TARGET=40
STAGE3_DURATION_SEC=30
STAGE3_TARGET=0

# Pausa entre iteraciones por VU (ms). 0 = martillo continuo
SLEEP_MS=0
